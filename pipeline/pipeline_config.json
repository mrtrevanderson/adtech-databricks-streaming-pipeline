{
  "name": "acme_ad_events_pipeline",
  "description": "Acme Media post-transaction ad targeting pipeline. Ingests e-commerce clickstream and user profile data, builds session behavioral signals, and produces real-time ad targeting recommendations after purchase events.",
  "catalog": "acme_catalog",
  "target": "acme_ad_pipeline",
  "libraries": [
    {
      "file": {
        "path": "/Workspace/Repos/adtech-databricks-streaming-pipeline/pipeline/01_bronze_ingestion.py"
      }
    },
    {
      "file": {
        "path": "/Workspace/Repos/adtech-databricks-streaming-pipeline/pipeline/02_silver_transforms.sql"
      }
    },
    {
      "file": {
        "path": "/Workspace/Repos/adtech-databricks-streaming-pipeline/pipeline/03_gold_ad_targeting.sql"
      }
    }
  ],
  "configuration": {
    "pipelines.enableTrackHistory": "true",
    "spark.databricks.delta.preview.enabled": "true",
    "events_path":   "/Volumes/acme_catalog/raw/ecommerce_events/",
    "profiles_path": "/Volumes/acme_catalog/raw/user_profiles/"
  },
  "clusters": [
    {
      "label": "default",
      "autoscale": {
        "min_workers": 2,
        "max_workers": 8,
        "mode": "ENHANCED"
      },
      "spark_conf": {
        "spark.databricks.delta.optimizeWrite.enabled": "true",
        "spark.databricks.delta.autoCompact.enabled": "true"
      }
    }
  ],
  "continuous": false,
  "development": true,
  "edition": "ADVANCED",
  "photon": true,
  "channel": "CURRENT",
  "event_log": {
    "catalog": "acme_catalog",
    "schema": "acme_ad_pipeline",
    "name": "acme_ad_pipeline_events"
  }
}
