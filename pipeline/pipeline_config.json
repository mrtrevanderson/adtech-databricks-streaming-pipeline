{
  "name": "acme_ad_events_pipeline",
  "description": "Acme Media post-transaction ad targeting pipeline. All layers implemented in SQL using Lakeflow SDP. Ingests e-commerce clickstream and user profile CSVs via read_files(), builds session behavioral signals, and produces real-time ad targeting recommendations after purchase events.",
  "catalog": "ius_unity_prod",
  "target": "sandbox",
  "libraries": [
    {
      "file": {
        "path": "/Workspace/Repos/adtech-databricks-streaming-pipeline/pipeline/01_bronze_ingestion.sql"
      }
    },
    {
      "file": {
        "path": "/Workspace/Repos/adtech-databricks-streaming-pipeline/pipeline/02_silver_transforms.sql"
      }
    },
    {
      "file": {
        "path": "/Workspace/Repos/adtech-databricks-streaming-pipeline/pipeline/03_gold_ad_targeting.sql"
      }
    }
  ],
  "configuration": {
    "pipelines.enableTrackHistory": "true"
  },
  "clusters": [
    {
      "label": "default",
      "autoscale": {
        "min_workers": 2,
        "max_workers": 8,
        "mode": "ENHANCED"
      },
      "spark_conf": {
        "spark.databricks.delta.optimizeWrite.enabled": "true",
        "spark.databricks.delta.autoCompact.enabled": "true"
      }
    }
  ],
  "continuous": false,
  "development": true,
  "edition": "ADVANCED",
  "photon": true,
  "channel": "CURRENT",
  "event_log": {
    "catalog": "ius_unity_prod",
    "schema": "sandbox",
    "name": "sandbox_pipeline_events"
  }
}
