%%{init: {'theme': 'dark'}}%%
flowchart TD
 %% SOURCES 
 subgraph SOURCES["SOURCES"]
 K["Kafka\nClick / Impression / Conversion events"]
 S["S3 / ADLS\nJSON landing zone"]
 P["Partner Feeds\nPublisher events Experian identity data"]
 end

 %% INGESTION 
 subgraph INGEST["INGESTION Auto Loader"]
 AL["cloudFiles\nSchema inference Evolution Exactly-once"]
 end

 %% BRONZE 
 subgraph BRONZE["BRONZE LAYER"]
 BR["bronze_ad_events\n\nRaw Append-only Full fidelity\n_ingest_timestamp _source_file\nNo transformations applied"]
 end

 %% SILVER 
 subgraph SILVER["SILVER LAYER"]
 SV["silver_ad_events\n\nWatermark: 10 min late tolerance\nDedup on event_id\nConsent filter: consent_flag = true\nDerived: event_date event_hour is_mobile\nCDF enabled for downstream CDC"]
 DQ["DLT Expectations\n\nvalid_event_type\nconsent_required\nnon_null_event_id\nnon_null_campaign\nviolations: dropped + logged"]
 end

 %% GOLD 
 subgraph GOLD["GOLD LAYER"]
 G1["gold_campaign_performance_hourly\n\nGrain: campaign x advertiser x publisher x geo x device x hour\nMetrics: impressions clicks conversions\nKPIs: CTR CVR eCPM revenue_usd\nZ-order: campaign_id, event_hour\nFeed: Live dashboard"]
 G2["gold_consumer_daily_signals\n\nGrain: consumer_id x event_date\nMetrics: daily clicks impressions conversions\nFeatures: engagement_score advertisers_interacted\nZ-order: consumer_id, event_date\nFeed: ML training pipeline"]
 end

 %% CONSUMERS 
 subgraph CONSUMERS["DOWNSTREAM CONSUMERS"]
 D1["Live Campaign Dashboard\nAdvertiser reporting real-time KPIs"]
 D2["ML Training Job\nAudience propensity models\nIdentity graph scoring"]
 D3["Delta Sharing\nPrivacy-first partner data sharing\nAcme Media x Databricks partnership"]
 D4["Billing Reconciliation\nCPA / CPL revenue attribution"]
 end

 %% FLOW 
 K --> AL
 S --> AL
 P --> AL
 AL -->|"Structured Streaming\nexactly-once"| BR
 BR -->|"Streaming read\nwatermark + dedup"| DQ
 DQ -->|"expect_or_drop\nviolations logged"| SV
 SV -->|"Materialized View\nbatch refresh"| G1
 SV -->|"Materialized View\ndaily refresh"| G2
 G1 --> D1
 G1 --> D4
 G2 --> D2
 G2 --> D3

 %% STYLES 
 classDef sourceStyle fill:#1e2d40,stroke:#2563eb,color:#93c5fd
 classDef ingestStyle fill:#1c2b1e,stroke:#16a34a,color:#86efac
 classDef bronzeStyle fill:#2d1f0e,stroke:#b45309,color:#fbbf24
 classDef silverStyle fill:#0c1929,stroke:#2563eb,color:#93c5fd
 classDef dqStyle fill:#1a0a0a,stroke:#dc2626,color:#fca5a5
 classDef goldStyle fill:#141a06,stroke:#65a30d,color:#bef264
 classDef consumerStyle fill:#1e1530,stroke:#7c3aed,color:#c4b5fd

 class K,S,P sourceStyle
 class AL ingestStyle
 class BR bronzeStyle
 class SV silverStyle
 class DQ dqStyle
 class G1,G2 goldStyle
 class D1,D2,D3,D4 consumerStyle
