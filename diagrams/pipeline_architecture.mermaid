%%{init: {'theme': 'dark'}}%%
flowchart TD

    subgraph SOURCES["SOURCES - E-Commerce Website"]
        EV["CSV: ecommerce_events\npage_view - add_to_cart - checkout_start - purchase"]
        UP["CSV: user_profiles\nConsumer identity - attributes - loyalty tier - CDC ops"]
    end

    subgraph INGEST["INGESTION - Auto Loader (Python)"]
        AL1["cloudFiles - CSV\nSchema declared - header=true\nschemaEvolutionMode: addNewColumns"]
        AL2["cloudFiles - CSV\nSchema declared - header=true\nCDC operation column preserved"]
    end

    subgraph BRONZE["BRONZE LAYER"]
        BR1["bronze_ecommerce_events\n--------------------------\nRaw clickstream - append-only\n_ingest_timestamp - _source_file\nNo transforms applied"]
        BR2["bronze_user_profiles_raw\n--------------------------\nRaw profile rows with operation\nINSERT - UPDATE - DELETE\nAll versions preserved"]
    end

    subgraph SILVER["SILVER LAYER"]
        SV1["silver_ecommerce_events\n--------------------------\nTECHNIQUE: Watermarks\nWatermark: 15 min late tolerance\nConsent filter - null checks\nDerived: line_total - is_purchase"]
        SV2["silver_user_profiles\n--------------------------\nTECHNIQUE: AUTO CDC\nAPPLY CHANGES INTO\nSCD Type 1 - keyed on user_id\nSequenced by updated_at"]
        SV3["silver_enriched_purchases\n--------------------------\nTECHNIQUE: Stream-Stream Join\nPurchase events JOIN user profiles\nEnriches WHO bought WHAT\nTargeting signals attached"]
        SV4["silver_session_summary\n--------------------------\nTECHNIQUE: Stateful Aggregation\nSession window per user+session\nFunnel counts - intent score\nConverted flag - revenue"]
    end

    subgraph GOLD["GOLD LAYER"]
        G1["gold_post_transaction_triggers\n--------------------------\nOne record per purchase\nRecommended ad categories\nSuggested bid price\nAd format by device\nFeed: Ad serving engine"]
        G2["gold_user_targeting_profile\n--------------------------\nAggregate profile per user\nBehavioral targeting tier\nCategory affinity\nConversion rate - LTV\nFeed: ML audience model"]
    end

    subgraph CONSUMERS["DOWNSTREAM CONSUMERS"]
        D1["Post-Transaction Ad Server\nServes personalized ad immediately after purchase"]
        D2["ML Audience Model\nRefreshes propensity scores and identity graph nightly"]
        D3["Campaign Reporting\nCTR - CVR - revenue by campaign and targeting tier"]
    end

    EV --> AL1
    UP --> AL2
    AL1 -->|"Structured Streaming\nexactly-once via checkpoint"| BR1
    AL2 -->|"Structured Streaming\nexactly-once via checkpoint"| BR2

    BR1 -->|"STREAM read\nwatermark + consent filter"| SV1
    BR2 -->|"APPLY CHANGES INTO\nAUTO CDC merge"| SV2

    SV1 -->|"Stream-stream join\npurchase events only"| SV3
    SV2 -->|"Stream-stream join\nprofile enrichment"| SV3
    SV1 -->|"Stateful GROUP BY\nsession window"| SV4

    SV3 -->|"Materialized View"| G1
    SV4 -->|"Materialized View"| G2

    G1 --> D1
    G1 --> D3
    G2 --> D2
    G2 --> D3

    classDef sourceStyle   fill:#1e2d40,stroke:#2563eb,color:#93c5fd
    classDef ingestStyle   fill:#1c2b1e,stroke:#16a34a,color:#86efac
    classDef bronzeStyle   fill:#2d1f0e,stroke:#b45309,color:#fbbf24
    classDef silverStyle   fill:#0c1929,stroke:#2563eb,color:#93c5fd
    classDef goldStyle     fill:#141a06,stroke:#65a30d,color:#bef264
    classDef consumerStyle fill:#1e1530,stroke:#7c3aed,color:#c4b5fd

    class EV,UP sourceStyle
    class AL1,AL2 ingestStyle
    class BR1,BR2 bronzeStyle
    class SV1,SV2,SV3,SV4 silverStyle
    class G1,G2 goldStyle
    class D1,D2,D3 consumerStyle
